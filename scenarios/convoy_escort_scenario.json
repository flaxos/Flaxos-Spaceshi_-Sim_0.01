  "tactical_notes": {
    "ship_class_differences": {
      "corvette": "Fast (280N thrust / 1200kg = high accel), agile (20 deg/s), 1 railgun + 2 PDCs. Glass cannon.",
      "frigate": "Balanced (380N / 2200kg), 2 railguns + 4 PDCs. Good all-rounder.",
      "destroyer": "Heavy (450N / 4000kg = slow accel), 3 railguns + 6 PDCs. Lots of firepower, poor maneuverability.",
      "freighter": "Powerful drives (600N) but massive (8000kg = still slow). Only 2 PDCs for self-defense."
    }
